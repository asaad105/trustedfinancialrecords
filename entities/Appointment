{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Client's full name"
    },
    "email": {
      "type": "string",
      "description": "Client's email address"
    },
    "phone": {
      "type": "string",
      "description": "Client's phone number"
    },
    "company_name": {
      "type": "string",
      "description": "Client's company name"
    },
    "service_interest": {
      "type": "string",
      "enum": [
        "bookkeeping",
        "tax_preparation",
        "financial_reporting",
        "advisory",
        "general"
      ],
      "description": "Service the client is interested in"
    },
    "preferred_date": {
      "type": "string",
      "format": "date",
      "description": "Preferred consultation date"
    },
    "preferred_time": {
      "type": "string",
      "description": "Preferred consultation time"
    },
    "business_challenge": {
      "type": "string",
      "description": "Brief description of the client's current challenge"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "completed",
        "cancelled"
      ],
      "default": "pending",
      "description": "Appointment status"
    },
    "conversation_summary": {
      "type": "string",
      "description": "Summary of the AI consultation conversation"
    }
  },
  "required": [
    "full_name",
    "email"
  ]
}
